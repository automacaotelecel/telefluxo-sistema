{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/server.ts",
    "src/modules/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/serverbackup.ts",
    "src/serverBK24.02.ts",
    "src/**/*backup*.ts",
    "src/**/*BK*.ts",
    "src/**/__tests__/**"
  ]
}